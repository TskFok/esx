{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ESX",
  "version": "0.1.0",
  "identifier": "com.ushopal.esx",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ESX",
        "width": 1480,
        "height": 960,
        "minWidth": 1240,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "allowLinkPreview": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

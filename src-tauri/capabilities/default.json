{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "ESX main window permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "http:default",
    "opener:default",
    "store:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://*"
        },
        {
          "url": "https://*"
        }
      ]
    }
  ]
}
